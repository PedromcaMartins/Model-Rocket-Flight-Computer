[
  {
    "label": "xtask check (clippy+build+test)",
    "command": "cargo",
    "args": ["run", "--package", "xtask", "--", "check"],
    "cwd": "${ZED_WORKTREE_ROOT}/code",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "xtask host (SITL)",
    "command": "cargo",
    "args": ["run", "--package", "xtask", "--", "host"],
    "cwd": "${ZED_WORKTREE_ROOT}/code",
    "use_new_terminal": false,
    "allow_concurrent_runs": false
  }
]
